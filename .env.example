# Required: your Google Gemini API key.
# This is only used server-side (Next.js API routes) — never exposed to the browser.
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=your_gemini_model_here

# Webhook endpoint for "Send for Official Review" (client-side, must keep NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_WEBHOOK_URL=https://your-tailscale-hostname/webhook